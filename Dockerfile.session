FROM alpine:3

RUN apk add --no-cache \
    bash \
    zsh \
    git \
    curl \
    wget \
    openssh-client \
    build-base \
    python3 \
    py3-pip \
    nodejs \
    npm \
    vim \
    less \
    htop \
    jq \
    ripgrep \
    fd \
    tree \
    tmux

# Set default shell
ENV SHELL=/bin/bash
ENV TERM=xterm-256color
ENV COLORTERM=truecolor
ENV LANG=en_US.UTF-8

# Create a non-root user
RUN adduser -D -s /bin/bash dev
USER dev
WORKDIR /home/dev

CMD ["/bin/bash", "-l"]
