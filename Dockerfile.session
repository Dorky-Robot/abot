FROM alpine:3

RUN apk add --no-cache \
    bash \
    zsh \
    git \
    curl \
    wget \
    openssh-client \
    build-base \
    python3 \
    py3-pip \
    nodejs \
    npm \
    vim \
    less \
    htop \
    jq \
    ripgrep \
    fd \
    tree \
    tmux \
    gcompat

# Set default shell
ENV SHELL=/bin/bash
ENV TERM=xterm-256color
ENV COLORTERM=truecolor
ENV LANG=en_US.UTF-8

# Create a non-root user
RUN adduser -D -s /bin/bash dev

# Install Claude Code via native installer to a system path that won't be
# shadowed by the bind mount on /home/dev
USER dev
RUN curl -fsSL https://claude.ai/install.sh | bash
USER root
RUN cp /home/dev/.local/bin/claude /usr/local/bin/claude && \
    chmod +x /usr/local/bin/claude
USER dev
WORKDIR /home/dev

CMD ["/bin/bash", "-l"]
