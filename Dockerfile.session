FROM alpine:3

RUN apk add --no-cache \
    bash \
    zsh \
    git \
    curl \
    wget \
    openssh-client \
    build-base \
    python3 \
    py3-pip \
    nodejs \
    npm \
    vim \
    less \
    htop \
    jq \
    ripgrep \
    fd \
    tree \
    tmux \
    && npm install -g @anthropic-ai/claude-code

# Set default shell
ENV SHELL=/bin/bash
ENV TERM=xterm-256color
ENV COLORTERM=truecolor
ENV LANG=en_US.UTF-8

# Create a non-root user
RUN adduser -D -s /bin/bash dev
USER dev
WORKDIR /home/dev

# Pre-seed Claude Code config so the interactive wizard is skipped.
# The hasCompletedOnboarding flag prevents the first-run "Select login method" screen.
RUN mkdir -p /home/dev/.claude && \
    echo '{"hasCompletedOnboarding":true,"hasCompletedAuthFlow":true}' > /home/dev/.claude/settings.json

CMD ["/bin/bash", "-l"]
