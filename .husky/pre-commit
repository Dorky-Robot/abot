#!/usr/bin/env bash
# .husky/pre-commit — fast, deterministic checks before every commit
#
# Hook chain:
#   1. Secrets scan   (gitleaks — BLOCKING)
#   2. Spell check    (typos — BLOCKING)
#   3. Formatting     (cargo fmt — BLOCKING)
#   4. Lint           (cargo clippy — BLOCKING)
#   5. Dart analysis  (dart analyze — BLOCKING, if flutter_client changed)
#
# Activate once per clone:
#   git config core.hooksPath .husky

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

warn() { echo "  WARN  $*" >&2; }
fail() { echo "  ERROR $*" >&2; exit 1; }
step() { echo ""; echo "==> $*"; }

# Check if any staged files match a pattern
staged_files_match() {
    git diff --cached --name-only | grep -q "$1" 2>/dev/null
}

# Determine step count based on whether Flutter files are staged
TOTAL_STEPS=4
if staged_files_match "^flutter_client/"; then
    TOTAL_STEPS=5
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  pre-commit checks (abot)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── 1. Secrets scan (BLOCKING) ────────────────────────────────────────────────
step "[1/$TOTAL_STEPS] Secrets scan (gitleaks)"
if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks git --pre-commit --no-banner --verbose; then
        fail "Secrets detected — commit blocked. Remove secrets before committing."
    fi
    echo "      OK  No secrets detected"
else
    warn "gitleaks not installed — skipping secrets scan."
    warn "Install: brew install gitleaks"
fi

# ── 2. Spell check (BLOCKING) ────────────────────────────────────────────────
step "[2/$TOTAL_STEPS] Spell check (typos)"
if command -v typos >/dev/null 2>&1; then
    if ! typos; then
        fail "Spelling errors found — commit blocked. Fix typos before committing."
    fi
    echo "      OK  No spelling errors"
else
    warn "typos not installed — skipping spell check."
    warn "Install: brew install typos-cli"
fi

# ── 3. Formatting (BLOCKING) ─────────────────────────────────────────────────
step "[3/$TOTAL_STEPS] Rust formatting (cargo fmt)"
if command -v cargo >/dev/null 2>&1; then
    if ! cargo fmt --all -- --check; then
        fail "Formatting errors — commit blocked. Run 'cargo fmt --all' to fix."
    fi
    echo "      OK  Rust code formatted correctly"
else
    warn "cargo not found — skipping Rust formatting check."
fi

# ── 4. Lint (BLOCKING) ───────────────────────────────────────────────────────
step "[4/$TOTAL_STEPS] Rust lint (cargo clippy)"
if command -v cargo >/dev/null 2>&1; then
    if ! cargo clippy --all-targets -- -D warnings 2>&1; then
        fail "Clippy warnings — commit blocked. Fix clippy issues before committing."
    fi
    echo "      OK  No clippy warnings"
else
    warn "cargo not found — skipping Rust lint check."
fi

# ── 5. Dart analysis (BLOCKING, only if flutter_client changed) ──────────────
if [ "$TOTAL_STEPS" -eq 5 ]; then
    step "[5/$TOTAL_STEPS] Dart analysis (dart analyze)"
    if command -v dart >/dev/null 2>&1; then
        if ! (cd flutter_client && dart analyze --fatal-infos 2>&1); then
            fail "Dart analysis errors — commit blocked. Fix issues in flutter_client/ before committing."
        fi
        echo "      OK  No Dart analysis issues"
    else
        warn "dart not found — skipping Dart analysis."
        warn "Install: https://docs.flutter.dev/get-started/install"
    fi
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  All pre-commit checks passed — proceeding with commit."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
